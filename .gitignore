# ── 虚拟环境 ──────────────────────────────────────────────────
.venv/
.venv-ml/

# ── Python 缓存 ────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── Jupyter ────────────────────────────────────────────────────
.ipynb_checkpoints/
Untitled*.ipynb

# ── Kaggle 数据集（体积过大，通过 setup_data.sh 下载）──────────
data/
dataset/

# ── 预计算的大型二进制文件（运行 notebook 可重新生成）─────────
laws_embeddings.npy     # 270MB — 法律条文嵌入向量
bge_embeddings.npy      # 11MB  — BGE 案例嵌入向量
art_to_bge.pkl          # 13MB  — 条文→BGE 共引索引

# ── 较小的派生文件（可选：提交可加速复现）───────────────────
# laws_citations.txt    # 3.6MB — 取消注释则忽略
# bge_keys.txt          # 104KB — 取消注释则忽略

# ── 提交文件（个人实验结果，不必共享）─────────────────────────
submission*.csv

# ── macOS ──────────────────────────────────────────────────────
.DS_Store
